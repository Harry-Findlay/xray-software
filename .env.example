# ─── Development ─────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Electron Store ────────────────────────────────────────────────────────────
# Encryption key for the local electron-store (settings, license token)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
STORE_ENCRYPTION_KEY=change-this-to-a-random-32-char-string

# ─── Database ─────────────────────────────────────────────────────────────────
# Optional: SQLCipher encryption key if using encrypted SQLite
# DB_ENCRYPTION_KEY=change-this-to-a-random-key

# ─── License Server ───────────────────────────────────────────────────────────
LICENSE_SERVER_URL=https://license.yourcompany.com

# RSA Public Key for verifying license JWTs (generate a keypair, deploy private key to license server)
# LICENSE_SERVER_PUBLIC_KEY= (set in licenseManager.js directly for security)

# ─── Code Signing (CI only — set as GitHub Secrets, not here) ─────────────────
# WINDOWS_CERT_BASE64=        Base64-encoded .p12 certificate
# WINDOWS_CERT_PASSWORD=      Certificate password
# APPLE_CERT_BASE64=          Base64-encoded Apple Developer certificate
# APPLE_CERT_PASSWORD=        Certificate password  
# KEYCHAIN_PASSWORD=          Temporary keychain password for CI
# APPLE_ID=                   your@apple.id (for notarization)
# APPLE_APP_SPECIFIC_PASSWORD= App-specific password from appleid.apple.com
# APPLE_TEAM_ID=              Your Apple Developer Team ID
