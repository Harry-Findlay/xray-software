{
  "appId": "com.yourcompany.dentalxraystudio",
  "productName": "Dental X-Ray Studio",
  "copyright": "Copyright \u00a9 2026 IT INFINITY LIMITED",
  "directories": {
    "output": "dist",
    "buildResources": "build"
  },
  "files": [
    "build/**/*",
    "src/main/**/*",
    "src/license/**/*",
    "node_modules/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "resources/postgres",
      "to": "postgres",
      "filter": [
        "**/*"
      ]
    },
    {
      "from": "resources/setup-db.bat",
      "to": "setup-db.bat"
    }
  ],
  "extraMetadata": {
    "installType": "server",
    "main": "src/main/main.js"
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "publisherName": "IT INFINITY LIMITED"
  },
  "nsis": {
    "warningsAsErrors": false,
    "oneClick": false,
    "allowToChangeInstallationDirectory": false,
    "perMachine": true,
    "deleteAppDataOnUninstall": false,
    "include": "installer/installer.nsh"
  },
  "artifactName": "Dental-XRay-Studio-Server-Setup-${version}.${ext}",
  "extends": null
}